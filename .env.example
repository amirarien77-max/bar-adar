VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# --- Email notifications (Supabase Edge Function secrets) ---
# Set these via: supabase secrets set RESEND_API_KEY=re_xxx
#                supabase secrets set NOTIFICATION_FROM_EMAIL="Bar Adar <noreply@yourdomain.com>"
#
# Resend: https://resend.com (free tier available)
# Verify your sending domain in Resend before production use.
#
# Optional server-side trigger (pg_net): run SQL from
# supabase/migrations/002_low_stock_email_notifications.sql
# and populate app_config with your function URL + service role key.
